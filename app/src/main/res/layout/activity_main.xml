<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">



    <!-- Scanline overlay (Alien Green) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0F39FF14"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Title -->
    <LinearLayout
        android:id="@+id/titleBlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/scrollMenu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.1"
        android:layout_marginTop="24dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VOID"
            android:textColor="@color/alien_green"
            android:textSize="64sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.3"
            android:shadowColor="@color/alien_green"
            android:shadowRadius="25"
            android:shadowDx="0"
            android:shadowDy="0"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ASCENSION"
            android:textColor="@color/alien_cyan"
            android:textSize="28sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.5"
            android:shadowColor="@color/alien_cyan"
            android:shadowRadius="15"
            android:shadowDx="0"
            android:shadowDy="0"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◈ XENOS INFILTRATION DETECTED ◈"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- Menu Card -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constrainedHeight="true"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/titleBlock"
        app:layout_constraintBottom_toTopOf="@id/tvBestScore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:id="@+id/cardMenu"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_cyberpunk_card"
            android:padding="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlay"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="☣  INITIATE ASCENSION"
                android:fontFamily="monospace"
                android:textSize="15sp"
                android:maxLines="1"
                android:ellipsize="none"
                android:letterSpacing="0.05"
                android:textColor="@color/alien_green"
                app:backgroundTint="#0A0F1E"
                app:strokeColor="@color/alien_green"
                app:strokeWidth="2dp"
                app:cornerRadius="4dp"
                android:layout_marginBottom="10dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectAvatar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="👤  SELECT BIOMASS"
                android:fontFamily="monospace"
                android:textSize="15sp"
                android:maxLines="1"
                android:textColor="@color/alien_cyan"
                app:backgroundTint="#0A0F1E"
                app:strokeColor="@color/alien_cyan"
                app:strokeWidth="2dp"
                app:cornerRadius="4dp"
                android:layout_marginBottom="10dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpgrades"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🧬  MUTATIONS"
                android:fontFamily="monospace"
                android:textSize="15sp"
                android:maxLines="1"
                android:textColor="@color/alien_purple"
                app:backgroundTint="#0A0F1E"
                app:strokeColor="@color/alien_purple"
                app:strokeWidth="2dp"
                app:cornerRadius="4dp"
                android:layout_marginBottom="10dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrestige"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="☢  PRESTIGE"
                android:fontFamily="monospace"
                android:textSize="15sp"
                android:maxLines="1"
                android:textColor="#FF8800"
                app:backgroundTint="#0A0F1E"
                app:strokeColor="#FF8800"
                app:strokeWidth="2dp"
                app:cornerRadius="4dp"
                android:layout_marginBottom="10dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnQuit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="✕  ABORT"
                android:fontFamily="monospace"
                android:textSize="15sp"
                android:maxLines="1"
                android:textColor="#FF4444"
                app:backgroundTint="#0A0F1E"
                app:strokeColor="#FF4444"
                app:strokeWidth="2dp"
                app:cornerRadius="4dp"
                android:layout_marginBottom="10dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheats"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="⌨  AUTH BYPASS"
                android:fontFamily="monospace"
                android:textSize="15sp"
                android:maxLines="1"
                android:textColor="#00FFFF"
                app:backgroundTint="#0A0F1E"
                app:strokeColor="#00FFFF"
                app:strokeWidth="2dp"
                app:cornerRadius="4dp"
                android:layout_marginBottom="10dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="⚙  CALIBRATION"
                android:fontFamily="monospace"
                android:textSize="15sp"
                android:maxLines="1"
                android:textColor="#FFFFFF"
                app:backgroundTint="#0A0F1E"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="2dp"
                app:cornerRadius="4dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Best Score -->
    <TextView
        android:id="@+id/tvBestScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HIGHEST BIOMASS: 0"
        android:textColor="#446644"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
