<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="matrix"
        android:contentDescription="background" />

    <!-- Scanline overlay (Alien Green) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0F39FF14"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Title -->
    <LinearLayout
        android:id="@+id/titleBlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VOID"
            android:textColor="@color/alien_green"
            android:textSize="72sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.3"
            android:shadowColor="@color/alien_green"
            android:shadowRadius="25"
            android:shadowDx="0"
            android:shadowDy="0"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ASCENSION"
            android:textColor="@color/alien_cyan"
            android:textSize="32sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.5"
            android:shadowColor="@color/alien_cyan"
            android:shadowRadius="15"
            android:shadowDx="0"
            android:shadowDy="0"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◈ XENOS INFILTRATION DETECTED ◈"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- Game Over Panel -->
    <LinearLayout
        android:id="@+id/gameOverPanel"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_cyberpunk_card"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/titleBlock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— BIOLOGICAL FAILURE —"
            android:textColor="#FF4444"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvGameOverScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BIOMASS: 0"
            android:textColor="@color/alien_acid"
            android:textSize="22sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tvGameOverWave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INFESTATION LVL 0"
            android:textColor="@color/alien_cyan"
            android:textSize="18sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tvGameOverKills"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ELIMINATIONS: 0"
            android:textColor="#AAAAAA"
            android:textSize="16sp"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- Menu Card -->
    <LinearLayout
        android:id="@+id/cardMenu"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_cyberpunk_card"
        android:padding="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="80dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlay"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="☣  INITIATE ASCENSION"
            android:fontFamily="monospace"
            android:textSize="16sp"
            android:maxLines="1"
            android:ellipsize="none"
            android:letterSpacing="0.05"
            android:textColor="@color/alien_green"
            app:backgroundTint="#0A0F1E"
            app:strokeColor="@color/alien_green"
            app:strokeWidth="2dp"
            app:cornerRadius="4dp"
            android:layout_marginBottom="14dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectAvatar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="👤  SELECT BIOMASS"
            android:fontFamily="monospace"
            android:textSize="16sp"
            android:maxLines="1"
            android:textColor="@color/alien_cyan"
            app:backgroundTint="#0A0F1E"
            app:strokeColor="@color/alien_cyan"
            app:strokeWidth="2dp"
            app:cornerRadius="4dp"
            android:layout_marginBottom="14dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpgrades"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🧬  MUTATIONS"
            android:fontFamily="monospace"
            android:textSize="16sp"
            android:maxLines="1"
            android:textColor="@color/alien_purple"
            app:backgroundTint="#0A0F1E"
            app:strokeColor="@color/alien_purple"
            app:strokeWidth="2dp"
            app:cornerRadius="4dp"
            android:layout_marginBottom="14dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrestige"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="☢  PRESTIGE"
            android:fontFamily="monospace"
            android:textSize="16sp"
            android:maxLines="1"
            android:textColor="#FF8800"
            app:backgroundTint="#0A0F1E"
            app:strokeColor="#FF8800"
            app:strokeWidth="2dp"
            app:cornerRadius="4dp"
            android:layout_marginBottom="14dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="✕  ABORT"
            android:fontFamily="monospace"
            android:textSize="16sp"
            android:maxLines="1"
            android:textColor="#FF4444"
            app:backgroundTint="#0A0F1E"
            app:strokeColor="#FF4444"
            app:strokeWidth="2dp"
            app:cornerRadius="4dp"/>
    </LinearLayout>

    <!-- Best Score -->
    <TextView
        android:id="@+id/tvBestScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HIGHEST BIOMASS: 0"
        android:textColor="#446644"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
