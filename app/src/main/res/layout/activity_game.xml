<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">

    <!-- Game Surface -->

    <!-- Move Joystick (bottom-left) -->
    <com.voidascension.engine.GameRenderer
        android:id="@+id/gameRenderer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <com.voidascension.ui.VirtualJoystick
        android:id="@+id/joystickMove"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintWidth_percent="0.2"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_min="100dp"
        app:layout_constraintWidth_max="160dp"/>

    <!-- Fire Joystick (bottom-right) -->
    <com.voidascension.ui.VirtualJoystick
        android:id="@+id/joystickFire"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintWidth_percent="0.2"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_min="100dp"
        app:layout_constraintWidth_max="160dp"/>

    <!-- Orientation Toggle Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOrientation"
        style="@style/VoidButton.Primary"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_margin="12dp"
        android:padding="0dp"
        app:icon="@drawable/ic_alien_rotate"
        app:iconSize="36dp"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconTint="@null"
        app:backgroundTint="#880A0F1E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnPause"/>

    <!-- Pause Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPause"
        style="@style/VoidButton.Primary"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_margin="12dp"
        android:padding="0dp"
        app:icon="@drawable/ic_alien_pause"
        app:iconSize="36dp"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconTint="@null"
        app:backgroundTint="#880A0F1E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Upgrade Overlay (responsive container) -->
    <FrameLayout
        android:id="@+id/upgradeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#DD02050A"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:scrollbars="none"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvUpgradeTitle"
                    style="@style/VoidText.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Adaptation"
                    android:textColor="@color/alien_green"
                    android:layout_marginTop="32dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <LinearLayout
                    android:id="@+id/upgradeContainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:clipToPadding="false"
                    app:layout_constraintWidth_max="600dp"
                    app:layout_constraintTop_toBottomOf="@id/tvUpgradeTitle"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>
    </FrameLayout>

    <!-- Pause Menu -->
    <LinearLayout
        android:id="@+id/pauseMenu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/alien_bg"
        android:padding="32dp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintWidth_percent="0.7"
        app:layout_constraintWidth_max="400dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="8dp">

        <TextView
            style="@style/VoidText.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM HALTED"
            android:textColor="@color/alien_cyan"
            android:layout_marginBottom="32dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResume"
            style="@style/VoidButton.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="RESUME LINK"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuit"
            style="@style/VoidButton.Danger"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="TERMINATE"
            app:backgroundTint="#1A0B0B"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
