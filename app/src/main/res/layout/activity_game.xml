<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">

    <!-- Game Surface -->

    <com.voidascension.engine.GameRenderer
        android:id="@+id/gameRenderer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Guidelines for HUD -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/glTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="16dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/glBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.95" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/glLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.05" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/glRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.95" />

    <!-- Move Joystick (bottom-left) -->
    <com.voidascension.ui.VirtualJoystick
        android:id="@+id/joystickMove"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="@id/glLeft"
        app:layout_constraintBottom_toBottomOf="@id/glBottom"
        app:layout_constraintWidth_percent="0.18"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_min="110dp"
        app:layout_constraintWidth_max="180dp"/>

    <!-- Fire Joystick (bottom-right) -->
    <com.voidascension.ui.VirtualJoystick
        android:id="@+id/joystickFire"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintEnd_toEndOf="@id/glRight"
        app:layout_constraintBottom_toBottomOf="@id/glBottom"
        app:layout_constraintWidth_percent="0.18"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_min="110dp"
        app:layout_constraintWidth_max="180dp"/>

    <!-- Orientation Toggle Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOrientation"
        style="@style/VoidButton.Primary"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:padding="0dp"
        app:icon="@drawable/ic_alien_rotate"
        app:iconSize="32dp"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconTint="@null"
        app:backgroundTint="#880A0F1E"
        app:layout_constraintTop_toTopOf="@id/glTop"
        app:layout_constraintEnd_toStartOf="@id/btnPause"
        android:layout_marginEnd="8dp"/>

    <!-- Pause Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPause"
        style="@style/VoidButton.Primary"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:padding="0dp"
        app:icon="@drawable/ic_alien_pause"
        app:iconSize="32dp"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconTint="@null"
        app:backgroundTint="#880A0F1E"
        app:layout_constraintTop_toTopOf="@id/glTop"
        app:layout_constraintEnd_toEndOf="@id/glRight"/>

    <!-- Upgrade Overlay (responsive container) -->
    <FrameLayout
        android:id="@+id/upgradeOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#DD02050A"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:scrollbars="none"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="48dp">

                <TextView
                    android:id="@+id/tvUpgradeTitle"
                    style="@style/VoidText.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Adaptation"
                    android:textColor="@color/alien_green"
                    android:layout_marginTop="48dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <LinearLayout
                    android:id="@+id/upgradeContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:clipToPadding="false"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/tvUpgradeTitle"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>
    </FrameLayout>

    <!-- Pause Menu -->
    <LinearLayout
        android:id="@+id/pauseMenu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/alien_bg"
        android:padding="32dp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintWidth_percent="0.6"
        app:layout_constraintWidth_max="380dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="8dp">

        <TextView
            style="@style/VoidText.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM HALTED"
            android:textColor="@color/alien_cyan"
            android:layout_marginBottom="32dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResume"
            style="@style/VoidButton.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="RESUME LINK"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            style="@style/VoidButton.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="AUDIO CALIBRATION"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2dp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuit"
            style="@style/VoidButton.Danger"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="TERMINATE"
            app:backgroundTint="#1A0B0B"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
