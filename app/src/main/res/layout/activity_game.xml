<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">

    <!-- Game Surface -->
    <com.voidascension.engine.GameRenderer
        android:id="@+id/gameRenderer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Move Joystick (bottom-left) -->
    <com.voidascension.ui.VirtualJoystick
        android:id="@+id/joystickMove"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintWidth_percent="0.2"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_min="100dp"
        app:layout_constraintWidth_max="160dp"/>

    <!-- Fire Joystick (bottom-right) -->
    <com.voidascension.ui.VirtualJoystick
        android:id="@+id/joystickFire"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintWidth_percent="0.2"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_min="100dp"
        app:layout_constraintWidth_max="160dp"/>

    <!-- Orientation Toggle Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOrientation"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_margin="12dp"
        android:text="🔄"
        android:textSize="30sp"
        android:padding="0dp"
        app:cornerRadius="8dp"
        app:backgroundTint="#44004488"
        android:textColor="#00FFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnPause"/>

    <!-- Pause Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPause"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_margin="12dp"
        android:text="⏸"
        android:textSize="35sp"
        android:padding="0dp"
        app:cornerRadius="8dp"
        app:backgroundTint="#44004488"
        android:textColor="#00FFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Upgrade Overlay (responsive container) -->
    <FrameLayout
        android:id="@+id/upgradeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#DD000000"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:scrollbars="none"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/upgradeContainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:clipToPadding="false"
                    app:layout_constraintWidth_max="600dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>
    </FrameLayout>

    <!-- Pause Menu -->
    <LinearLayout
        android:id="@+id/pauseMenu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#E6080B14"
        android:padding="32dp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintWidth_percent="0.7"
        app:layout_constraintWidth_max="400dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PAUSED"
            android:textColor="#00FFFF"
            android:textSize="30sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.2"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResume"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="RESUME"
            android:fontFamily="monospace"
            android:textColor="#00FFFF"
            app:backgroundTint="#0A0F1E"
            app:strokeColor="#00FFFF"
            app:strokeWidth="2dp"
            app:cornerRadius="8dp"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="QUIT"
            android:fontFamily="monospace"
            android:textColor="#FF4444"
            app:backgroundTint="#0A0F1E"
            app:strokeColor="#FF4444"
            app:strokeWidth="2dp"
            app:cornerRadius="8dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
