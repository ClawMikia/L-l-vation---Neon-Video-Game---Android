<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="#0A0F1E"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvUpgradeName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upgrade Name"
            android:textColor="@color/alien_green"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvUpgradeDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="#BBBBBB"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp"
            android:minLines="2"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvUpgradeCost"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 SHARDS"
                android:textColor="@color/alien_acid"
                android:textSize="12sp"
                android:fontFamily="monospace"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuy"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="EVOLVE"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/alien_green"
                app:backgroundTint="#002211"
                app:strokeColor="@color/alien_green"
                app:strokeWidth="1dp"
                app:cornerRadius="4dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
