<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Deep space base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#080B14"/>
        </shape>
    </item>

    <!-- Radial glow - top -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:centerX="0.5"
                android:centerY="0.1"
                android:startColor="#1500AAFF"
                android:endColor="#00000000"/>
        </shape>
    </item>

    <!-- Radial glow - bottom -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="300dp"
                android:centerX="0.5"
                android:centerY="0.9"
                android:startColor="#18FF00FF"
                android:endColor="#00000000"/>
        </shape>
    </item>

</layer-list>
