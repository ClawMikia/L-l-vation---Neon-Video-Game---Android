<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#2200FFFF"/>
            <stroke android:width="2dp" android:color="#00FFFF"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#1100FFFF"/>
            <stroke android:width="2dp" android:color="#00FFFF"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#110A0F1E"/>
            <stroke android:width="1dp" android:color="#44444444"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0A0F1E"/>
            <stroke android:width="2dp" android:color="#8800FFFF"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

</selector>
