<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Alien Shape Styles -->
    <style name="ShapeAppearance.Alien" parent="">
        <item name="cornerFamily">cut</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.Alien.Small" parent="">
        <item name="cornerFamily">cut</item>
        <item name="cornerSize">6dp</item>
    </style>

    <style name="Theme.VoidAscension" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/alien_cyan</item>
        <item name="colorPrimaryDark">@color/alien_bg</item>
        <item name="colorAccent">@color/alien_purple</item>
        <item name="android:windowBackground">@color/alien_bg</item>
        <item name="android:statusBarColor">@color/alien_bg</item>
        <item name="android:navigationBarColor">@color/alien_bg</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- Base Text Styles -->
    <style name="VoidText">
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="VoidText.Title">
        <item name="android:textColor">@color/alien_cyan</item>
        <item name="android:textSize">28sp</item>
        <item name="android:letterSpacing">0.2</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="VoidText.Body">
        <item name="android:textColor">@color/void_text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="VoidText.Dim">
        <item name="android:textColor">@color/void_text_dim</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Base Button Styles -->
    <style name="VoidButton" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">monospace</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">@color/alien_card</item>
        <item name="strokeWidth">2dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Alien.Small</item>
    </style>

    <style name="VoidButton.Primary">
        <item name="android:textColor">@color/alien_cyan</item>
        <item name="strokeColor">@color/alien_cyan</item>
    </style>

    <style name="VoidButton.Secondary">
        <item name="android:textColor">@color/alien_green</item>
        <item name="strokeColor">@color/alien_green</item>
    </style>

    <style name="VoidButton.Danger">
        <item name="android:textColor">@color/void_red</item>
        <item name="strokeColor">@color/void_red</item>
    </style>

    <style name="VoidCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/alien_card</item>
        <item name="strokeWidth">2dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Alien</item>
    </style>

</resources>
