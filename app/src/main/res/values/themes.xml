<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.VoidAscension" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/void_cyan</item>
        <item name="colorPrimaryDark">@color/void_card</item>
        <item name="colorAccent">@color/void_magenta</item>
        <item name="android:windowBackground">@color/void_bg</item>
        <item name="android:statusBarColor">@color/void_card</item>
        <item name="android:navigationBarColor">@color/void_bg</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- Base Text Styles -->
    <style name="VoidText">
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="VoidText.Title">
        <item name="android:textColor">@color/void_cyan</item>
        <item name="android:textSize">28sp</item>
        <item name="android:letterSpacing">0.2</item>
    </style>

    <style name="VoidText.Body">
        <item name="android:textColor">@color/void_text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="VoidText.Dim">
        <item name="android:textColor">@color/void_text_dim</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Base Button Styles -->
    <style name="VoidButton" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">monospace</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">@color/void_card</item>
        <item name="strokeWidth">2dp</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="VoidButton.Primary">
        <item name="android:textColor">@color/void_cyan</item>
        <item name="strokeColor">@color/void_cyan</item>
    </style>

    <style name="VoidButton.Danger">
        <item name="android:textColor">@color/void_red</item>
        <item name="strokeColor">@color/void_red</item>
    </style>

</resources>
